    "optimize": "npx tsx optimizer/cli/index.ts",
    "qa:tier0": "node scripts/qa/validate-tier0-gate.cjs",
    "qa:skip-policy": "node scripts/qa/check-skipped-tests.cjs",
    "qa:e2e-docs": "node scripts/qa/check-e2e-doc-drift.cjs",

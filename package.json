  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-sw.cjs",
    "build:dev": "vite build --mode development",
    "atlas": "node scripts/build-atlas.mjs",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:budget": "node scripts/eslint-warning-budget.cjs",
    "typecheck": "tsc -b",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "validate": "npm run lint:check && npm run typecheck && npm run format:check",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:ci": "vitest run --reporter=dot --coverage",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",

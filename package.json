    "lint:dal": "bash scripts/check-duplicate-service-wrappers.sh",
    "health:metrics": "node scripts/codebase-health-metrics.cjs",
    "qa:android15-edge": "node scripts/qa/check-android-15-edge-to-edge.cjs --require-native",

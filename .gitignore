# Supabase CLI temp files
supabase/.temp/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.env
.env.*
!.env.example
!.env.production.example

# MCP Configuration (contains API keys)
.mcp.json
.cursor/mcp_config.json
.claude/worktrees/
.claude/command-log.txt

# Hallmark skill — runtime install via `npx skills add nutlope/hallmark`.
# 27 MB of reference markdown; reproducible on demand; not vendored in-repo.
.agents/skills/hallmark/
.claude/skills/hallmark

# Optimizer runtime data
optimizer/.data/
reports/optimizer/

# Loop state (ephemeral, session-scoped)
tmp/loop-status/*
tmp/loop-history/*
!tmp/loop-status/.gitkeep
!tmp/loop-history/.gitkeep
ios-release/fastlane/README.md
ios-release/fastlane/report.xml
coverage/

# Crash dumps / local scratch artifacts
core
core.*
jules-scratch/

# Playwright test artifacts
test-results/
playwright-report/

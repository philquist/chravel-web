{
  "name": "chravel-launch-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts ChravelLaunch out/chravel-launch.mp4",
    "render:gif": "remotion render src/index.ts ChravelLaunch out/chravel-launch.gif --image-format png",
    "render:trip-creation": "remotion render src/index.ts TripCreationFlow out/broll-trip-creation.mp4",
    "render:calendar": "remotion render src/index.ts LiveSharedCalendar out/broll-live-calendar.mp4",
    "render:concierge": "remotion render src/index.ts AIConciergeAction out/broll-ai-concierge.mp4",
    "render:payments": "remotion render src/index.ts PaymentSplit out/broll-payment-split.mp4",
    "render:media": "remotion render src/index.ts MediaVault out/broll-media-vault.mp4",
    "render:polls-tasks": "remotion render src/index.ts PollsAndTasks out/broll-polls-tasks.mp4",
    "render:tab-nav": "remotion render src/index.ts TabNavigationHero out/broll-tab-nav.mp4",
    "render:before-after": "remotion render src/index.ts BeforeAfterChaos out/broll-before-after.mp4",
    "render:broll-overlay": "remotion render src/index.ts BRollOverlay out/broll-overlay.mp4",
    "render:all-broll": "npm run render:trip-creation && npm run render:calendar && npm run render:concierge && npm run render:payments && npm run render:media && npm run render:polls-tasks && npm run render:tab-nav && npm run render:before-after && npm run render:broll-overlay",
    "capture:frames": "node scripts/capture-demo-frames.mjs",
    "render:homepage-demo": "node scripts/render-remotion.mjs ../public/videos/chravel-homepage-demo-60.mp4 HomepageProductDemo60",
    "still:homepage-demo-poster": "remotion still src/index.ts HomepageProductDemo60 ../public/videos/chravel-homepage-demo-60-poster.jpg --frame=0 --image-format=jpeg --jpeg-quality=82",
    "render:homepage-hero": "remotion render src/index.ts HomepageHeroDemo ../public/videos/chravel-homepage-hero.mp4 --codec=h264 --crf=23",
    "render:mobile-demo": "remotion render src/index.ts MobileAppDemo ../public/videos/chravel-mobile-demo.mp4 --codec=h264 --crf=23",
    "still:hero-poster": "remotion still src/index.ts HomepageHeroDemo ../public/videos/chravel-homepage-hero-poster.jpg --frame=30 --image-format=jpeg --jpeg-quality=85",
    "still:mobile-poster": "remotion still src/index.ts MobileAppDemo ../public/videos/chravel-mobile-demo-poster.jpg --frame=30 --image-format=jpeg --jpeg-quality=85",
    "render:marketing": "mkdir -p ../public/videos && npm run render:homepage-hero && npm run still:hero-poster && npm run render:mobile-demo && npm run still:mobile-poster"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.447",
    "@remotion/cli": "^4.0.447",
    "@remotion/fonts": "^4.0.447",
    "@remotion/google-fonts": "^4.0.447",
    "@remotion/player": "^4.0.447",
    "@remotion/renderer": "^4.0.447",
    "@remotion/tailwind": "^4.0.447",
    "@remotion/transitions": "^4.0.447",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.447"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.2"
  }
}

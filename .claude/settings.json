{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Grep(*)",
      "Glob(*)",
      "Bash(git status)",
      "Bash(git branch --show-current)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)"
    ],
    "ask": [
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git checkout main)",
      "Bash(git switch main)",
      "Bash(git worktree add:*)"
    ],
    "deny": ["Bash(git push origin main)", "Bash(git push --force:*)", "Bash(git reset --hard:*)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "background": true
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/memory-primer.sh",
            "background": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-create.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-sensitive-files.sh\""
          },
          {
            "type": "prompt",
            "prompt": "If the file being edited is a critical path file (useAuth, useTrip, trip loading pages, Supabase client, RLS policies, payment hooks, or auth guards), remind Claude to verify this change won't cause Trip Not Found, auth desync, or RLS leaks. Otherwise approve silently."
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-pr-tests.sh\"",
            "timeout": 300000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-review-reminder.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write \"$CLAUDE_FILE_PATHS\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-lint.sh\""
          },
          {
            "type": "command",
            "command": "npm run typecheck --if-present"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-command.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-test-gate.sh\"",
            "timeout": 180000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/impl-discipline.sh\""
          }
        ]
      }
    ]
  },
  "pluginMarketplaces": [
    {
      "name": "superpowers-marketplace",
      "source": "obra/superpowers-marketplace"
    },
    {
      "name": "agent-browser-marketplace",
      "source": "vercel-labs/agent-browser"
    }
  ],
  "plugins": [
    {
      "name": "superpowers",
      "marketplace": "superpowers-marketplace",
      "version": "4.3.1"
    },
    {
      "name": "agent-browser",
      "marketplace": "agent-browser-marketplace",
      "version": "latest"
    },
    {
      "name": "chravel",
      "version": "1.0.0"
    }
  ]
}

# Example environment variables for local development

# PostHog Analytics
# Get from: https://app.posthog.com/project/settings
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase Configuration
VITE_SUPABASE_URL=
# Preferred modern key:
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy compatibility (optional if publishable key is set):
VITE_SUPABASE_ANON_KEY=

# Google Maps (Required for Places tab to work)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# AI provider routing (server-side edge functions)
# AI_PROVIDER=gemini (default, direct Gemini API)
# AI_PROVIDER=lovable (rollback mode, route all unified AI calls through Lovable gateway)
# GEMINI_ENABLE_LOVABLE_FALLBACK=true enables automatic Lovable fallback on Gemini failure
# AI_PROVIDER=gemini
# GEMINI_ENABLE_LOVABLE_FALLBACK=true
# GEMINI_API_KEY=
# GEMINI_FLASH_MODEL=gemini-3.1-flash  # Text/chat model (non-realtime voice)
# GEMINI_TTS_API_KEY=  # Optional dedicated key for TTS function; falls back to GEMINI_API_KEY
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# LOVABLE_API_KEY=
# Demo concierge endpoint (separate unauth endpoint, disabled by default)
# ENABLE_DEMO_CONCIERGE=false
# DEMO_CONCIERGE_RPM=3
# DEMO_CONCIERGE_RPH=12

# Voice feature flags (ship-safe hardening)
VITE_VOICE_LIVE_ENABLED=true
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud
# Voice provider: openai (default), livekit, off
VITE_AI_VOICE_PROVIDER=openai
# VITE_VOICE_DIAGNOSTICS_ENABLED=false  # Extra console logs for debugging

# Gemini Live voice preset used by AI Concierge Voice (optional)
# Default is "Charon".
# VITE_GEMINI_VOICE_NAME=Charon

# Gemini Live model override for concierge voice (optional)
# Default: gemini-live-2.5-flash-native-audio
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio  # Realtime voice model

# OAuth Configuration
# Google OAuth is enabled by default. Set to 'false' to hide the button.
# Configure in Supabase Dashboard: Authentication > Providers > Google
# VITE_OAUTH_GOOGLE_ENABLED=false

# Super Admin Emails (comma-separated, used for client-side admin checks)
# VITE_SUPER_ADMIN_EMAILS=admin@example.com,founder@example.com
# Demo super-admin bypass is intentionally opt-in only.
# VITE_SUPER_ADMIN_ENABLE_DEMO_EMAIL=true

# Stripe Payments
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_* for development, pk_live_* for production
VITE_STRIPE_PUBLISHABLE_KEY=
# Enable/disable Stripe payment processing (default: true)
# VITE_ENABLE_STRIPE_PAYMENTS=true

# RevenueCat (iOS/Android in-app purchases)
# VITE_REVENUECAT_ENABLED=true
# VITE_REVENUECAT_IOS_API_KEY=
# VITE_REVENUECAT_ANDROID_API_KEY=
# VITE_REVENUECAT_EXPLORER_ENTITLEMENT_ID=chravel_explorer
# VITE_REVENUECAT_FREQUENT_CHRAVELER_ENTITLEMENT_ID=chravel_frequent_chraveler

# Venmo Payment Integration (optional)
# VITE_VENMO_CLIENT_ID=

# GetStream Chat (messaging migration)
# Get from: https://getstream.io/dashboard/ → App → Access Keys
VITE_STREAM_API_KEY=

# Web Push Notifications (VAPID)
# Generate keys with: npx ts-node scripts/generate-vapid-keys.ts
# Public key goes here (safe to expose in frontend)
VITE_VAPID_PUBLIC_KEY=
# Private key goes in Supabase secrets (VAPID_PRIVATE_KEY) - NEVER expose in frontend

# Link Unfurl / Preview Service (optional)
# VITE_UNFURL_BASE_URL=

# App Version (injected at build time, fallback: 1.0.0)
# VITE_APP_VERSION=1.0.0

# Voice Feature Flags (additional)
# VITE_VOICE_DEBUG=false

# AI Concierge
# VITE_ENABLE_AI_CONCIERGE=true
# VITE_CONCIERGE_TTS_ENABLED=false

# Demo Mode
# VITE_ENABLE_DEMO_MODE=false

# Push Notifications
# VITE_ENABLE_PUSH_NOTIFICATIONS=true

# Error Tracking
# VITE_SENTRY_DSN=

# Analytics
# VITE_GA_MEASUREMENT_ID=
# VITE_MIXPANEL_TOKEN=

# Super Admin
# VITE_SUPER_ADMIN_EMAILS=admin@example.com
# VITE_SUPER_ADMIN_ENABLE_DEMO_EMAIL=true

# ─── Server-Side Secrets (set in Supabase Dashboard, NOT in .env) ───
# ⚠️  DO NOT set these in .env or .env.local — they will NOT work and risk exposure.
#     Configure ONLY via: Supabase Dashboard > Edge Functions > Secrets
#     See docs/ACTIVE/SECRET_ROTATION.md for rotation procedures.
#
# SUPABASE_SERVICE_ROLE_KEY    — Supabase service role (admin) key
# SUPER_ADMIN_EMAILS           — Optional server-side CSV extension for super-admin bypass
# SUPER_ADMIN_ENABLE_DEMO_EMAIL — Set true only for controlled demo/staging use
# STRIPE_SECRET_KEY            — Stripe secret key (sk_test_* or sk_live_*)
# STRIPE_WEBHOOK_SECRET        — Stripe webhook endpoint signing secret
# GEMINI_API_KEY               — Google Gemini API key
# LOVABLE_API_KEY              — Lovable AI gateway key
# RESEND_API_KEY               — Resend email service key
# RESEND_FROM_EMAIL            — Sender email address
# VAPID_PRIVATE_KEY            — VAPID private key for web push
# GOOGLE_MAPS_API_KEY          — Server-side Google Maps key
# GOOGLE_VISION_API_KEY        — Google Vision OCR key
# GOOGLE_CLIENT_ID             — Google OAuth client ID
# GOOGLE_CLIENT_SECRET         — Google OAuth client secret
# GOOGLE_REDIRECT_URI          — Google OAuth redirect URI
# FIRECRAWL_API_KEY            — Firecrawl web scraping key
# AWS_ACCESS_KEY_ID            — AWS access key (for S3/Textract)
# AWS_SECRET_ACCESS_KEY        — AWS secret key
# AWS_REGION                   — AWS region (default: us-east-1)
# VERTEX_PROJECT_ID            — GCP project for TTS + FCM (not voice)
# VERTEX_SERVICE_ACCOUNT_KEY   — Base64-encoded GCP service account JSON
# VERTEX_LOCATION              — Vertex AI location (default: us-central1)
# LIVEKIT_API_KEY              — LiveKit server API key (server-side only)
# LIVEKIT_API_SECRET           — LiveKit server API secret (server-side only)
# LIVEKIT_URL                  — LiveKit server URL (e.g., wss://your-project.livekit.cloud)
# APNS_PRIVATE_KEY             — Apple Push Notification private key
# APNS_KEY_ID                  — Apple Push Notification key ID
# APNS_TEAM_ID                 — Apple Developer Team ID
# FCM_SERVER_KEY               — Firebase Cloud Messaging server key
# CRON_SECRET                  — Secret for cron job authentication
# OAUTH_STATE_SIGNING_SECRET   — OAuth state signing secret
# GMAIL_TOKEN_ENCRYPTION_KEY   — Gmail token encryption key
# STREAM_API_KEY               — GetStream Chat API key (public key)
# STREAM_API_SECRET            — GetStream Chat API secret (server-only)

# OpenAI Realtime voice (server-side secrets in Supabase)
# OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=alloy
# Valid Realtime voices include: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar
